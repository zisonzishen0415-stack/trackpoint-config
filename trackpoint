        local pointer=$(get_param "Device Accel Constant Deceleration")
        local accel=$(get_param "Device Accel Velocity Scaling")
        local profile=$(get_param "Device Accel Profile" | cut -d'.' -f1)
        cat > "$PROFILE_DIR/${name}.conf" <<EOF
