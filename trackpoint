NATURAL_SCROLL=$natural
EOF
    fi
    echo -e "${GREEN}Ôťô ňĚ▓ń┐Łňşś '$name'${NC}"
    sleep 1
}

list_profiles() {
    if [ ! -d "$PROFILE_DIR" ] || [ -z "$(ls -A $PROFILE_DIR 2>/dev/null)" ]; then
        return 1
    fi
    return 0
}

load_profile() {
    if ! list_profiles; then
        echo -e "${YELLOW}ŠŚáń┐ŁňşśŠľ╣Šíł${NC}"
        sleep 1
        return
    fi
    clear
    echo -e "${BOLD}====== ňŐáŔŻŻŠľ╣Šíł ======${NC}"
    echo ""
    local profiles=($(ls -1 "$PROFILE_DIR" | sed 's/\.conf$//'))
    local i=1
    for p in "${profiles[@]}"; do 
        echo -e "${CYAN}$i${NC}. $p"
        i=$((i+1))
    done
    echo -e "${CYAN}q${NC}. Ŕ┐öňŤ×"
    echo ""
    read -p "ÚÇëŠőę: " num
    [ "$num" = "q" ] && return
    local idx=$((num-1))
    [ $idx -lt 0 ] || [ $idx -ge ${#profiles[@]} ] && return
    local name="${profiles[$idx]}"
    source "$PROFILE_DIR/${name}.conf"
    if [ "$DRIVER" = "evdev" ]; then
        xinput set-prop "$DEVICE" "Evdev Wheel Emulation Inertia" "$SCROLL"
        xinput set-prop "$DEVICE" "Device Accel Constant Deceleration" "$POINTER"
        xinput set-prop "$DEVICE" "Device Accel Velocity Scaling" "$ACCEL"
        xinput set-prop "$DEVICE" "Device Accel Profile" "$PROFILE"
        [ "$NATURAL_SCROLL" = "1" ] && xinput set-prop "$DEVICE" "Evdev Wheel Emulation Axes" 6 7 5 4 || xinput set-prop "$DEVICE" "Evdev Wheel Emulation Axes" 6 7 4 5
    else
        xinput set-prop "$DEVICE" "libinput Scrolling Pixel Distance" "$SCROLL"
        xinput set-prop "$DEVICE" "libinput Accel Speed" "$POINTER"
        xinput set-prop "$DEVICE" "libinput Natural Scrolling Enabled" "$NATURAL_SCROLL"
    fi
    echo -e "${GREEN}Ôťô ňĚ▓ňŐáŔŻŻ '$name'${NC}"
    sleep 1
}

