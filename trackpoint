save_config() {
    mkdir -p "$HOME/.config"
    local natural=$(get_natural_scroll)
    if [ "$DRIVER" = "evdev" ]; then
        local scroll=$(get_param "Evdev Wheel Emulation Inertia")
        local pointer=$(get_param "Device Accel Constant Deceleration")
        local accel=$(get_param "Device Accel Velocity Scaling")
        local profile=$(get_param "Device Accel Profile" | cut -d'.' -f1)
        cat > "$CONFIG" <<EOF
DRIVER=$DRIVER
SCROLL=$scroll
POINTER=$pointer
ACCEL=$accel
PROFILE=$profile
NATURAL_SCROLL=$natural
EOF
        [ "$natural" = "1" ] && local axes="6 7 5 4" || local axes="6 7 4 5"
        generate_autostart_evdev "$scroll" "$pointer" "$accel" "$profile" "$axes"
    else
        local scroll=$(get_param "Scrolling Pixel Distance")
        local pointer=$(get_param "Accel Speed")
        cat > "$CONFIG" <<EOF
DRIVER=$DRIVER
SCROLL=$scroll
POINTER=$pointer
NATURAL_SCROLL=$natural
EOF
        generate_autostart_libinput "$scroll" "$pointer" "$natural"
    fi
    chmod +x "$HOME/.config/trackpoint-autostart.sh"
    
    mkdir -p "$HOME/.config/systemd/user"
    cat > "$HOME/.config/systemd/user/trackpoint.service" <<EOF
[Unit]
Description=Apply TrackPoint configuration
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=oneshot
ExecStart=%h/.config/trackpoint-autostart.sh
RemainAfterExit=yes

[Install]
WantedBy=graphical-session.target
EOF
    systemctl --user daemon-reload 2>/dev/null
    systemctl --user enable trackpoint.service 2>/dev/null
    
    mkdir -p "$HOME/.config/autostart"
    cat > "$HOME/.config/autostart/trackpoint.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=TrackPoint Config
Exec=$HOME/.config/trackpoint-autostart.sh
Hidden=false
NoDisplay=false
X-GNOME-Autostart-enabled=true
EOF
    
    echo -e "${GREEN}Ôťô ÚůŹšŻ«ňĚ▓ń┐Łňşś´╝îÚçŹňÉ»ňÉÄŔç¬ňŐĘňŐáŔŻŻ${NC}"
    sleep 1
}

