}

generate_autostart_evdev() {
    local scroll="$1" pointer="$2" accel="$3" profile="$4" axes="$5"
    cat > "$HOME/.config/trackpoint-autostart.sh" <<'AUTOSTART_EOF'
#!/bin/bash
LOG="$HOME/.config/trackpoint/trackpoint.log"
mkdir -p "$(dirname "$LOG")"
echo "$(date '+%Y-%m-%d %H:%M:%S'): TrackPoint autostart started" >> "$LOG"

DEVICE="TPPS/2 IBM TrackPoint"

wait_for_device() {
    for i in {1..30}; do
        if xinput list-props "$DEVICE" &>/dev/null; then
            echo "$(date '+%Y-%m-%d %H:%M:%S'): Device found after ${i} attempts" >> "$LOG"
            return 0
        fi
        sleep 0.5
    done
    echo "$(date '+%Y-%m-%d %H:%M:%S'): ERROR: Device not found after 15 seconds" >> "$LOG"
    return 1
}

apply_settings() {
    local scroll="$1" pointer="$2" accel="$3" profile="$4" axes="$5"
    
    xinput set-prop "$DEVICE" "Evdev Wheel Emulation Inertia" "$scroll" && \
        echo "$(date '+%Y-%m-%d %H:%M:%S'): Scroll inertia = $scroll" >> "$LOG"
    xinput set-prop "$DEVICE" "Device Accel Constant Deceleration" "$pointer" && \
        echo "$(date '+%Y-%m-%d %H:%M:%S'): Pointer decel = $pointer" >> "$LOG"
    xinput set-prop "$DEVICE" "Device Accel Velocity Scaling" "$accel" && \
        echo "$(date '+%Y-%m-%d %H:%M:%S'): Velocity scaling = $accel" >> "$LOG"
    xinput set-prop "$DEVICE" "Device Accel Profile" "$profile" && \
        echo "$(date '+%Y-%m-%d %H:%M:%S'): Accel profile = $profile" >> "$LOG"
    xinput set-prop "$DEVICE" "Evdev Wheel Emulation Axes" $axes && \
        echo "$(date '+%Y-%m-%d %H:%M:%S'): Wheel axes = $axes" >> "$LOG"
}

if wait_for_device; then
    apply_settings SCROLL_PLACEHOLDER POINTER_PLACEHOLDER ACCEL_PLACEHOLDER PROFILE_PLACEHOLDER AXES_PLACEHOLDER
    echo "$(date '+%Y-%m-%d %H:%M:%S'): Settings applied successfully" >> "$LOG"
else
    echo "$(date '+%Y-%m-%d %H:%M:%S'): Failed to apply settings" >> "$LOG"
    exit 1
fi
AUTOSTART_EOF
    sed -i "s/SCROLL_PLACEHOLDER/$scroll/g; s/POINTER_PLACEHOLDER/$pointer/g; s/ACCEL_PLACEHOLDER/$accel/g; s/PROFILE_PLACEHOLDER/$profile/g; s/AXES_PLACEHOLDER/$axes/g" "$HOME/.config/trackpoint-autostart.sh"
}

