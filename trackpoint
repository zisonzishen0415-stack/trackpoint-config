        local y_down=$(get_param "$param" | cut -d'(' -f2 | cut -d')' -f1)
    fi
    while true; do
        clear
        echo -e "${BOLD}====== ňĆŹňÉĹŠ╗ÜňŐĘ ======${NC}"
        echo ""
        [ "$y_down" = "4" ] && echo -e "ňŻôňëŹ: ${GREEN}[ň╝ÇňÉ»]${NC} (ňćůň«╣ŔĚčÚÜĆŠëőŠîç)" || echo -e "ňŻôňëŹ: ${YELLOW}[ňů│ÚŚş]${NC} (ń╝áš╗čŠ╗ÜňŐĘ)"
