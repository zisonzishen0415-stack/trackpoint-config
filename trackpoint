#!/bin/bash
DEVICE="TPPS/2 IBM TrackPoint"
CONFIG="$HOME/.config/trackpoint.conf"
PROFILE_DIR="$HOME/.config/trackpoint-profiles"
LOG_DIR="$HOME/.config/trackpoint"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

if ! xinput list-props "$DEVICE" &>/dev/null; then
    echo -e "${RED}ŠëżńŞŹňł░Ŕ«żňĄç: $DEVICE${NC}"
    xinput list | grep -i trackpoint
    exit 1
fi

if xinput list-props "$DEVICE" | grep -q "libinput"; then
    DRIVER="libinput"
else
    DRIVER="evdev"
fi

mkdir -p "$LOG_DIR"

get_param() {
    xinput list-props "$DEVICE" | grep "$1" | awk -F':' '{print $NF}' | tr -d ' \t'
}

set_param() {
    if xinput set-prop "$DEVICE" "$1" $2 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

scroll_user_to_real() {
    local user_val=$1
    [ "$DRIVER" = "evdev" ] && echo $((51 - user_val * 5)) || echo $((110 - user_val * 10))
}

scroll_real_to_user() {
    local real_val=$1
    [ "$DRIVER" = "evdev" ] && echo $(((51 - real_val) / 5)) || echo $(((110 - real_val) / 10))
}

pointer_user_to_real() {
    local user_val=$1
    [ "$DRIVER" = "evdev" ] && echo "scale=2; 2.05 - $user_val * 0.15" | bc || echo "scale=2; -1.2 + $user_val * 0.2" | bc
}

pointer_real_to_user() {
    local real_val=$1
    [ "$DRIVER" = "evdev" ] && echo "scale=0; (2.05 - $real_val) / 0.15" | bc || echo "scale=0; ($real_val + 1.2) / 0.2" | bc
}

show_bar() {
    local val=$1 max=$2 label=$3
    local filled=$((val * 10 / max))
    [ $filled -gt 10 ] && filled=10
    [ $filled -lt 0 ] && filled=0
    local empty=$((10 - filled))
    printf "${CYAN}%s${NC} [" "$label"
    for i in $(seq 1 $filled); do printf "${GREEN}Ôľł${NC}"; done
    for i in $(seq 1 $empty); do printf "${YELLOW}ÔľĹ${NC}"; done
    printf "] ${BOLD}%d${NC}/%d" $val $max
}

get_natural_scroll() {
    if [ "$DRIVER" = "evdev" ]; then
        local current=$(get_param "Evdev Wheel Emulation Axes" | tr -d '()')
        local y_down=$(echo "$current" | awk '{print $4}')
        [ "$y_down" = "4" ] && echo "1" || echo "0"
    else
        get_param "Natural Scrolling Enabled" | cut -d'(' -f2 | cut -d')' -f1
    fi
}

show_status() {
    echo -e "${BOLD}Úę▒ňŐĘŠĘíň╝Ć: ${GREEN}$DRIVER${NC}"
    echo ""
    if [ "$DRIVER" = "evdev" ]; then
        local scroll_real=$(get_param "Evdev Wheel Emulation Inertia" | cut -d'.' -f1)
        local scroll_user=$(scroll_real_to_user $scroll_real)
        local pointer_real=$(get_param "Device Accel Constant Deceleration")
        local pointer_user=$(pointer_real_to_user $pointer_real)
        local accel=$(get_param "Device Accel Velocity Scaling" | cut -d'.' -f1)
        local profile=$(get_param "Device Accel Profile" | cut -d'.' -f1)
        local profile_name="Šť¬ščą"
        [ "$profile" = "2" ] && profile_name="š╗ĆňůŞ"
        [ "$profile" = "3" ] && profile_name="ň╣│Š╗Ĺ"
        [ "$profile" = "4" ] && profile_name="š«ÇňŹĽ"
        local natural=$(get_natural_scroll)
        show_bar $scroll_user 10 "Š╗ÜňŐĘ"; echo -e "  (${scroll_real})"
        show_bar $pointer_user 10 "ŠîçÚĺł"; echo -e "  (${pointer_real})"
        show_bar $accel 100 "ňŐáÚÇč"; echo -e "  (${profile_name})"
        [ "$natural" = "1" ] && echo -e "ňĆŹňÉĹ: ${GREEN}[ň╝ÇňÉ»]${NC}" || echo -e "ňĆŹňÉĹ: ${YELLOW}[ňů│ÚŚş]${NC}"
    else
        local scroll_real=$(get_param "Scrolling Pixel Distance" | cut -d'.' -f1)
        local scroll_user=$(scroll_real_to_user $scroll_real)
        local pointer_real=$(get_param "Accel Speed")
        local pointer_user=$(pointer_real_to_user $pointer_real)
        local natural=$(get_natural_scroll)
        show_bar $scroll_user 10 "Š╗ÜňŐĘ"; echo -e "  (${scroll_real})"
        show_bar $pointer_user 10 "ŠîçÚĺł"; echo -e "  (${pointer_real})"
        [ "$natural" = "1" ] && echo -e "ňĆŹňÉĹ: ${GREEN}[ň╝ÇňÉ»]${NC}" || echo -e "ňĆŹňÉĹ: ${YELLOW}[ňů│ÚŚş]${NC}"
    fi
    echo ""
    if [ -f "$CONFIG" ]; then
        echo -e "${BLUE}ňĚ▓ń┐ŁňşśÚůŹšŻ«: $(stat -c %y "$CONFIG" 2>/dev/null | cut -d'.' -f1)${NC}"
    else
        echo -e "${YELLOW}Šť¬ń┐ŁňşśÚůŹšŻ«${NC}"
    fi
}

