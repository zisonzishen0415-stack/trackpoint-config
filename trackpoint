    while true; do
        clear
        echo -e "${BOLD}====== Ŕ░âŔŐéŠ╗ÜňŐĘÚÇčň║Ž ======${NC}"
        echo ""
        show_bar $user_val 10 "ňŻôňëŹ"; echo ""
        echo ""
        echo -e "${CYAN}1${NC} = ňó×ňŐá (ŠŤ┤ň┐ź)    ${CYAN}2${NC} = ňçĆň░Ĺ (ŠŤ┤Šůó)"
        echo -e "${CYAN}t${NC} = ŠÁőŔ»ĽŠĘíň╝Ć       ${CYAN}q${NC} = Ŕ┐öňŤ×"
        echo ""
        read -s -n 1 opt
        case "$opt" in
            1) 
                user_val=$((user_val + 1)); [ $user_val -gt 10 ] && user_val=10
                real_val=$(scroll_user_to_real $user_val)
                if set_param "$param" $real_val; then
